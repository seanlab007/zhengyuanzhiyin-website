# 生产环境配置
# 将此文件复制为 .env.production 并填入实际值

# 应用配置
NODE_ENV=production
PORT=3000

# 数据库配置
# 格式: mysql://user:password@host:port/database
DATABASE_URL=mysql://root:password@localhost:3306/zhengyuanzhiyin

# OAuth配置
VITE_APP_ID=your_app_id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://oauth.manus.im

# JWT密钥
JWT_SECRET=your_jwt_secret_key_here

# 支付配置
WECHAT_APPID=your_wechat_appid
WECHAT_SECRET=your_wechat_secret
WECHAT_MCHID=your_wechat_mchid
WECHAT_API_KEY=your_wechat_api_key

ALIPAY_APPID=your_alipay_appid
ALIPAY_PRIVATE_KEY=your_alipay_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key

# 文件存储配置
AWS_S3_BUCKET=your_s3_bucket
AWS_S3_REGION=your_s3_region
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# LLM配置
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4

# 企业微信配置
WECHAT_WORK_CORPID=your_corpid
WECHAT_WORK_SECRET=your_secret
WECHAT_WORK_AGENTID=your_agentid

# 日志配置
LOG_LEVEL=info
LOG_DIR=/var/log/zhengyuanzhiyin-app

# 监控配置
SENTRY_DSN=your_sentry_dsn

# 域名配置
DOMAIN=www.zhengyuanzhiyin.com
HTTPS=true
